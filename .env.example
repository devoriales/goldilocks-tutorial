# Goldilocks Tutorial — Environment Variables
# Copy this file to .env and source it before running scripts:
#   cp .env.example .env && source .env

# k3d cluster name
CLUSTER_NAME=goldilocks-demo

# Goldilocks installation namespace
GOLDILOCKS_NAMESPACE=goldilocks

# Sample application namespace
APP_NAMESPACE=metrics-app

# Goldilocks Helm chart version
GOLDILOCKS_CHART_VERSION=10.4.0

# Goldilocks container image (new registry as of v4.15.0)
GOLDILOCKS_IMAGE=us-docker.pkg.dev/fairwinds-ops/oss/goldilocks
GOLDILOCKS_TAG=v4.15.1

# Dashboard local port (for port-forward)
DASHBOARD_PORT=8080
